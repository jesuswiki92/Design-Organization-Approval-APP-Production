# Frame UI-only — solo se conservan las rutas locales necesarias.

# Root folder for MANUALLY created projects (Crear Proyecto Nuevo modal).
DOA_PROJECTS_NEW_ROOT=C:/Users/Jesús Andrés/Desktop/Aplicaciones - Desarrollo/Design Organization Approval - APP Production/02. Datos DOA/05. Proyectos/01. Proyectos Nuevos/02. Proyectos nuevos

# Master templates folder (*.dotx).
DOA_PLANTILLAS_ROOT=C:/Users/Jesús Andrés/Desktop/Aplicaciones - Desarrollo/Design Organization Approval - APP Production/02. Datos DOA/01. Plantillas

# Microsoft Graph (delegated / OAuth user flow) — automations/inbound-email
# App registration multi-tenant + cuentas personales MSA. Permiso DELEGADO
# Mail.ReadWrite + offline_access. El authority real es `/common` (hardcoded
# en código), no se usa AZURE_AD_TENANT_ID en este flujo, pero se conserva
# como referencia.
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
# OUTLOOK_MAILBOX es informativo (cuál es el buzón delegado conectado);
# Graph se llama vía /me y NO usa esta variable en la URL.
OUTLOOK_MAILBOX=
# Redirect URI registrada en Azure (debe coincidir exactamente).
MICROSOFT_REDIRECT_URI=http://localhost:3010/api/auth/microsoft/callback
# Se rellena UNA VEZ tras autorizar la cuenta en /api/auth/microsoft/login.
# Pegar aquí el secret que devuelve el callback. A partir de ahí, el cron
# usa este refresh_token para obtener access_tokens automáticamente.
MICROSOFT_REFRESH_TOKEN=
