    {
      "parameters": {
        "jsonSchemaExample": "{\n  \"questions\": [\n    \"Please provide the existing DOA project code.\",\n    \"What is the target aircraft configuration or serial applicability for this request?\"\n  ]\n}"
      },
      "id": "followup_parser",
      "name": "Structured Output Parser Interactive",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.2,
      "position": [
        864,
        480
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const original = $('Form Client DOA Interactivo').item.json;\nconst output = $json.output || {};\nconst aiQuestions = Array.isArray(output.questions) ? output.questions.map((q) => (q || '').toString().trim()).filter(Boolean) : [];\nconst questions = [];\nif ((original['Project type'] || '') === 'Modification to an existing project' && !(original['Existing project code'] || '').toString().trim()) {\n  questions.push('Please provide the existing DOA project code for the project you want to modify.');\n}\nfor (const question of aiQuestions) {\n  if (!questions.includes(question)) questions.push(question);\n}\nreturn { json: { ...$json, questions, has_questions: questions.length > 0, follow_up_text: '' } };"
      },
      "id": "normalize_questions",
      "name": "Normalizar Preguntas",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        992,
        304
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "leftValue": "={{ $json.has_questions }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if_questions",
      "name": "Hay Preguntas",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1200,
