    {
      "parameters": {
        "jsCode": "const lines = [];\nfor (const item of $input.all()) {\n  const json = item.json || {};\n  const keys = Object.keys(json).filter((key) => key !== 'questions');\n  const answerKey = keys[0];\n  const question = json.questions || '';\n  const answer = answerKey ? json[answerKey] : '';\n  if (question && answer) {\n    lines.push(`Question: ${question}`);\n    lines.push(`Answer: ${answer}`);\n  }\n}\nreturn [{ json: { follow_up_text: lines.join('\\n') } }];"
      },
      "id": "collect_followups",
      "name": "Consolidar Seguimiento",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1824,
        80
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const original = $('Form Client DOA Interactivo').item.json;\nconst clean = (value) => {\n  const text = (value ?? '').toString().trim();\n  return text || null;\n};\nconst required = (value, label) => {\n  const text = (value ?? '').toString().trim();\n  if (!text) throw new Error(`Missing required field: ${label}`);\n  return text;\n};\nconst companyName = required(original['Company name'], 'Company name');\nconst country = required(original['Country'], 'Country');\nconst contactFirstName = required(original['Contact first name'], 'Contact first name');\nconst contactEmail = required(original['Contact email'], 'Contact email');\nconst manufacturer = required(original['Aircraft manufacturer'], 'Aircraft manufacturer');\nconst model = required(original['Aircraft model'], 'Aircraft model');\nconst projectType = required(original['Project type'], 'Project type');\nconst description = required(original['Request description'], 'Request description');\nconst followUpText = clean($json.follow_up_text);\nconst existingProjectCode = clean(original['Existing project code']);\nconst client = {\n  name: companyName,\n  vat_tax_id: clean(original['VAT / Tax ID']),\n  country: country,\n  city: null,\n  address: null,\n  phone: clean(original['Contact phone']),\n  website: null,\n  is_active: true,\n  notes: null,\n};\nconst contacto = {\n  name: contactFirstName,\n  last_name: clean(original['Contact last name']),\n  email: contactEmail,\n  phone: clean(original['Contact phone']),\n  job_title: null,\n  is_primary: true,\n  is_active: true,\n};\nconst classification = projectType === 'Modification to an existing project'\n  ? 'Client solicita modificacion a project existente'\n  : 'Client solicita project new';\nconst bodyLines = [\n  `Tipo de solicitud: ${projectType}`,\n  `Manufacturer: ${manufacturer}`,\n  `Model: ${model}`,\n  `Matricula: ${clean(original['Registration']) || ''}`,\n  `Codigo project existente: ${existingProjectCode || ''}`,\n  `Description: ${description}`,\n  '',\n  `Empresa: ${companyName}`,\n  `Country: ${country}`,\n  `Contacto: ${contactFirstName} ${clean(original['Contact last name']) || ''}`.trim(),\n  `Email contacto: ${contactEmail}`,\n];\nif (followUpText) {\n  bodyLines.push('');\n  bodyLines.push('Preguntas de seguimiento:');\n  bodyLines.push(followUpText);\n}\nconst intake = {\n  sender: contactEmail,\n  subject: `Form interactivo DOA - ${companyName} - ${model}`,\n  original_body: bodyLines.join('\\n'),\n  classification,\n  ai_response: '',\n};\nreturn { json: { client, contacto, intake } };"
      },
