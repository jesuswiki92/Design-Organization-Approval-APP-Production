        512,
        304
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Initial DOA intake:\n{{ $json.initial_summary }}",
        "hasOutputParser": true,
        "messages": {
          "messageValues": [
            {
              "type": "HumanMessagePromptTemplate",
              "message": "=You are assisting a DOA management intake process. Read the initial intake and decide whether any clarification questions are needed before the request can be routed internally.\n\nRules:\n- Ask at most 2 follow-up questions.\n- Ask only if the information is genuinely incomplete or ambiguous.\n- Do not ask for data already provided.\n- Prefer project-critical clarifications such as intended scope, aircraft configuration context, target timeline, operator context, or missing reference information.\n- If project type is modification to an existing project and no existing project code is present, include a question asking for that code.\n- Questions must be clear for an external client.\n- Output must be only the structured list required by the parser."
            }
          ]
        }
      },
      "id": "followup_llm",
      "name": "Preguntas de Seguimiento DOA",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.5,
      "position": [
        704,
        304
      ]
    },
    {
      "parameters": {
        "model": "o3-mini",
        "options": {}
      },
      "id": "followup_model",
      "name": "OpenAI Chat Model Interactive",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.1,
      "position": [
        640,
        480
      ],
      "credentials": {
        "openAiApi": {
          "id": "vAmNhoKH5n8YHlp6",
          "name": "OpenAi account"
