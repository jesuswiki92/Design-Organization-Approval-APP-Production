    {
      "id": "prepare_contact_native",
      "name": "Preparar Contacto Nativo",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2140,
        320
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const createdClient = $json || {};\nconst payload = $('Preparar Payloads Nativo').item.json || {};\nconst cliente = (createdClient.id ? createdClient : (createdClient.data && createdClient.data[0]) ? createdClient.data[0] : null) || createdClient;\nif (!cliente.id) throw new Error('No se pudo recuperar el id del cliente creado.');\nreturn {\n  json: {\n    contacto: {\n      cliente_id: cliente.id,\n      nombre: payload.contacto.nombre,\n      apellidos: payload.contacto.apellidos,\n      email: payload.contacto.email,\n      telefono: payload.contacto.telefono,\n      cargo: payload.contacto.cargo,\n      es_principal: true,\n      activo: true,\n    },\n    intake: payload.intake,\n    cliente,\n  },\n};"
      }
    },
