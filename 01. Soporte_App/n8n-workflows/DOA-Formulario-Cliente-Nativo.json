    {
      "id": "prepare_payloads_native",
      "name": "Preparar Payloads Nativo",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1660,
        320
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const clean = (value) => {\n  const text = (value ?? '').toString().trim();\n  return text || null;\n};\nconst required = (value, label) => {\n  const text = (value ?? '').toString().trim();\n  if (!text) throw new Error(`Missing required field: ${label}`);\n  return text;\n};\nconst companyName = required($json['Company name'], 'Company name');\nconst country = required($json['Country'], 'Country');\nconst contactFirstName = required($json['Contact first name'], 'Contact first name');\nconst contactEmail = required($json['Contact email'], 'Contact email');\nconst manufacturer = required($json['Aircraft manufacturer'], 'Aircraft manufacturer');\nconst model = required($json['Aircraft model'], 'Aircraft model');\nconst projectType = required($json['Project type'], 'Project type');\nconst registration = required($json['Registration'], 'Registration');\nconst description = required($json['Modification / request description'], 'Modification / request description');\nconst cliente = {\n  nombre: companyName,\n  cif_vat: clean($json['VAT / Tax ID']),\n  pais: country,\n  ciudad: clean($json['City']),\n  direccion: clean($json['Address']),\n  telefono: clean($json['Company phone']),\n  web: clean($json['Website']),\n  activo: true,\n  notas: null,\n};\nconst contacto = {\n  nombre: contactFirstName,\n  apellidos: clean($json['Contact last name']),\n  email: contactEmail,\n  telefono: clean($json['Contact phone']),\n  cargo: clean($json['Position / Role']),\n  es_principal: true,\n  activo: true,\n};\nconst clasificacion = projectType === 'Modification to an existing project'\n  ? 'Cliente solicita modificacion a proyecto existente'\n  : 'Cliente solicita proyecto nuevo';\nconst intake = {\n  remitente: contactEmail,\n  asunto: `Formulario nativo DOA - ${companyName} - ${model}`,\n  cuerpo_original: [\n    `Tipo de solicitud: ${projectType}`,\n    `Fabricante: ${manufacturer}`,\n    `Modelo: ${model}`,\n    `Matricula: ${registration}`,\n    `Descripcion: ${description}`,\n    '',\n    `Empresa: ${companyName}`,\n    `Pais: ${country}`,\n    `Ciudad: ${cliente.ciudad || ''}`,\n    `Direccion: ${cliente.direccion || ''}`,\n    `Telefono empresa: ${cliente.telefono || ''}`,\n    `Web: ${cliente.web || ''}`,\n    '',\n    `Contacto: ${contacto.nombre} ${contacto.apellidos || ''}`.trim(),\n    `Email contacto: ${contacto.email}`,\n    `Telefono contacto: ${contacto.telefono || ''}`,\n    `Cargo: ${contacto.cargo || ''}`,\n  ].join('\\n'),\n  clasificacion,\n  respuesta_ia: '',\n};\nreturn { json: { cliente, contacto, intake } };"
      }
    },
