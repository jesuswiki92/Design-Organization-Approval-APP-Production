# Frame UI-only — solo se conservan las rutas locales necesarias.
DOA_PROJECTS_NEW_ROOT=
DOA_PLANTILLAS_ROOT=

# Microsoft Graph (delegated / OAuth user flow) — automations/inbound-email
# AZURE_AD_TENANT_ID se mantiene por compatibilidad con la app registration,
# pero el flujo delegado usa el authority `/common` (no el tenant).
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
OUTLOOK_MAILBOX=
# Redirect URI registrada en Azure (debe coincidir exactamente).
MICROSOFT_REDIRECT_URI=http://localhost:3010/api/auth/microsoft/callback
# Se rellena tras hacer login una vez en /api/auth/microsoft/login.
MICROSOFT_REFRESH_TOKEN=
